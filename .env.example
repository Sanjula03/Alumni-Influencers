# ===========================================
# Alumni Influencers - Environment Variables
# ===========================================
# Copy this file to .env and fill in the values

# --- Server ---
PORT=3000
NODE_ENV=development

# --- MySQL Database ---
DB_HOST=localhost
DB_PORT=3306
DB_NAME=alumni_influencers
DB_USER=root
DB_PASS=your_mysql_password

# --- Session ---
SESSION_SECRET=generate-a-long-random-string-here

# --- Email (SMTP) ---
# For testing, create a free account at https://ethereal.email/
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=your-ethereal-user@ethereal.email
SMTP_PASS=your-ethereal-password

# --- App ---
APP_URL=http://localhost:3000
ALLOWED_EMAIL_DOMAIN=eastminster.ac.uk

# --- Rate Limiting ---
API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10
