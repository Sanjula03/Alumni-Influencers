<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Forgot Password - Alumni Analytics</title>
  <style>
    body { font-family: sans-serif; background: #f3f4f6; display: flex; justify-content: center; align-items: center; height: 100vh; margin: 0; }
    .card { background: white; padding: 30px; border-radius: 8px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); width: 350px; }
    h2 { margin-top: 0; text-align: center; }
    .form-group { margin-bottom: 15px; }
    label { display: block; margin-bottom: 5px; color: #374151; font-size: 14px; }
    input { width: 100%; padding: 10px; border: 1px solid #d1d5db; border-radius: 4px; box-sizing: border-box; }
    button { width: 100%; padding: 10px; background: #f59e0b; color: white; border: none; border-radius: 4px; cursor: pointer; font-size: 16px; margin-top: 10px; }
    button:hover { background: #d97706; }
    .footer-links { text-align: center; margin-top: 15px; font-size: 14px; }
    .footer-links a { color: #4f46e5; text-decoration: none; }
  </style>
</head>
<body>
  <div class="card">
    <h2>Reset Password</h2>
    <p style="font-size: 14px; color: #6b7280; text-align: center; margin-bottom: 20px;">
      Enter your email address and we'll send you a link to reset your password.
    </p>
    <%- include('../partials/flashData') %>
    
    <form action="/auth/forgot-password" method="POST">
      <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
      <div class="form-group">
        <label>Email Address</label>
        <input type="email" name="email" required>
      </div>
      <button type="submit">Send Reset Link</button>
    </form>
    
    <div class="footer-links">
      <p>Remembered your password? <a href="/auth/login">Login</a></p>
    </div>
  </div>
</body>
</html>
