<style>
  .top-nav {
    height: 80px;
    background: rgba(255, 255, 255, 0.7);
    backdrop-filter: blur(20px) saturate(180%);
    -webkit-backdrop-filter: blur(20px) saturate(180%);
    border-bottom: 1px solid rgba(0,0,0,0.05);
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 60px;
  }
  
  .nav-brand {
    display: flex;
    align-items: center;
    gap: 16px;
    font-size: 18px;
    font-weight: 900;
    letter-spacing: -0.04em;
    color: #000;
  }

  .nav-brand svg {
    fill: #000;
    width: 24px;
    height: 24px;
  }

  .nav-menu {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 32px;
    align-items: center;
  }

  .nav-item a {
    color: #64748b;
    text-decoration: none;
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    display: flex;
    align-items: center;
    gap: 8px;
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    padding: 8px 0;
    position: relative;
  }

  .nav-item a.active {
    color: #000;
    background: rgba(0, 0, 0, 0.03);
    border-radius: 12px;
    padding: 8px 16px;
  }

  .nav-item a::after {
    content: "";
    position: absolute;
    bottom: -6px;
    left: 50%;
    transform: translateX(-50%);
    width: 0;
    height: 3px;
    background: #000;
    border-radius: 10px;
    transition: width 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .nav-item a.active::after {
    width: 20px; /* Small centered professional bar */
  }

  .nav-item a:hover::after {
    width: 40px;
  }

  .nav-actions {
    display: flex;
    align-items: center;
  }

  .logout-btn {
    background: #000;
    color: #fff;
    border: none;
    padding: 10px 24px;
    border-radius: 100px;
    font-size: 13px;
    font-weight: 800;
    cursor: pointer;
    transition: all 0.2s;
    display: flex;
    align-items: center;
    gap: 10px;
    box-shadow: 0 10px 20px -5px rgba(0,0,0,0.2);
  }

  .logout-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 15px 30px -10px rgba(0,0,0,0.3);
    background: #222;
  }

  .logout-btn:active {
    transform: translateY(0);
  }
</style>

<nav class="top-nav">
  <div class="nav-brand">
    <svg viewBox="0 0 24 24"><path d="M12 3L1 9l4 2.18v6L12 21l7-3.82v-6l2-1.09V17h2V9L12 3z"/></svg>
    Alumni Influencers
  </div>
  
  <ul class="nav-menu">
    <li class="nav-item"><a href="/dashboard">Dashboard</a></li>
    <li class="nav-item"><a href="/dashboard/alumni">Browse</a></li>
    <li class="nav-item"><a href="/dashboard/profile">My Profile</a></li>
    <% if(typeof userRole !== 'undefined' && (userRole === 'alumnus' || userRole === 'admin')) { %>
      <li class="nav-item"><a href="/bids">Bidding</a></li>
    <% } %>
    <li class="nav-item"><a href="/analytics/charts">Analytics</a></li>
    <li class="nav-item"><a href="/export">Reports</a></li>
    <% if(typeof userRole !== 'undefined' && (userRole === 'developer' || userRole === 'admin')) { %>
      <li class="nav-item"><a href="/api-keys">API Keys</a></li>
    <% } %>
  </ul>
  
  <div class="nav-actions">
    <form action="/auth/logout" method="POST" style="margin:0;">
      <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
      <button type="submit" class="logout-btn">
        Logout
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path></svg>
      </button>
    </form>
  </div>
</nav>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const currentPath = window.location.pathname;
    const navLinks = document.querySelectorAll('.nav-item a');
    
    navLinks.forEach(link => {
      const linkPath = link.getAttribute('href');
      // Exact match for dashboard to avoid matching everything
      if (linkPath === currentPath) {
        link.classList.add('active');
      } else if (linkPath !== '/dashboard' && currentPath.startsWith(linkPath)) {
        // Partial match for sub-pages, but skip root dashboard
        link.classList.add('active');
      }
    });
  });
</script>
