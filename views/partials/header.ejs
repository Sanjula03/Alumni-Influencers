<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>University Analytics Dashboard</title>
  <style>
    /* CSS Variables for Sharp Enterprise Minimal UI */
    :root {
      --primary-color: #000000; /* Pure Black for actions */
      --primary-hover: #333333;
      --bg-color: #fafafa; /* Very light grey */
      --card-bg: #ffffff;
      --text-main: #111827;
      --text-muted: #6b7280;
      --border-color: #eaeaea; /* Sharp thin borders */
      --success: #059669;
      --danger: #dc2626;
      --warning: #d97706;
      --top-nav-height: 64px;
    }

    body {
      margin: 0;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
      background-color: var(--bg-color);
      color: var(--text-main);
      display: flex;
      flex-direction: column; /* Stack top-nav and main-content vertically */
      min-height: 100vh;
    }

    /* Layout structure */
    .app-container {
      display: flex;
      flex-direction: column;
      width: 100%;
    }

    .main-content {
      flex: 1;
      padding: 40px;
      margin-top: var(--top-nav-height); /* Offset for fixed top nav */
      max-width: 1400px;
      margin-left: auto;
      margin-right: auto;
      width: 100%;
      box-sizing: border-box;
    }

    /* We no longer use .with-sidebar, but leaving class for safety */
    .main-content.with-sidebar {
      margin-left: auto; 
    }

    h1, h2, h3, h4, h5 { color: var(--text-main); font-weight: 600; letter-spacing: -0.02em; }
    
    /* Alerts/Flash messages */
    .alert {
      padding: 12px 16px;
      margin-bottom: 24px;
      border-radius: 4px; /* Sharp corners */
      border: 1px solid;
      font-size: 14px;
    }
    .alert-error { background-color: #fef2f2; border-color: #fca5a5; color: #991b1b; }
    .alert-success { background-color: #ecfdf5; border-color: #a7f3d0; color: #065f46; }

    /* Button styles */
    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      padding: 8px 16px;
      font-size: 14px;
      font-weight: 500;
      border: 1px solid transparent;
      border-radius: 4px; /* Sharp corners */
      cursor: pointer;
      text-decoration: none;
      transition: background 0.15s, border-color 0.15s, color 0.15s;
    }
    .btn-primary { 
      background: var(--primary-color); 
      color: white; 
    }
    .btn-primary:hover { 
      background: var(--primary-hover);
    }
    .btn-danger { background-color: transparent; border: 1px solid #fca5a5; color: var(--danger); }
    .btn-danger:hover { background-color: #fef2f2; border-color: var(--danger); }
    
    .card {
      background: var(--card-bg);
      border-radius: 6px;
      border: 1px solid var(--border-color);
      box-shadow: 0 1px 2px rgba(0,0,0,0.02); /* Almost invisible shadow */
      padding: 24px;
      margin-bottom: 24px;
    }

    .top-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 24px;
      padding-bottom: 16px;
      border-bottom: 1px solid var(--border-color);
    }

    /* Form styles */
    input[type="text"], input[type="password"], input[type="email"], input[type="number"], select {
      background-color: #ffffff;
      color: var(--text-main);
      border: 1px solid var(--border-color);
      padding: 8px 12px;
      border-radius: 4px; /* Sharp corners */
      outline: none;
      font-size: 14px;
      transition: border-color 0.15s, box-shadow 0.15s;
    }
    input:focus, select:focus {
      border-color: #000000;
      box-shadow: 0 0 0 1px #000000;
    }
    label {
      color: var(--text-main);
      font-size: 13px;
      font-weight: 500;
      margin-bottom: 6px;
      display: block;
    }

    /* Page loading bar (rubric: "proper loading states") */
    .page-loader {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 3px;
      background: var(--primary-color);
      z-index: 9999;
      animation: loadProgress 0.8s ease-out forwards;
    }
    @keyframes loadProgress {
      0% { width: 0; opacity: 1; }
      80% { width: 100%; opacity: 1; }
      100% { width: 100%; opacity: 0; }
    }

    /* Metrics grid responsive */
    @media (max-width: 768px) {
      .main-content { padding: 20px; }
    }
  </style>
</head>
<body>
<!-- Page loading bar — animates on every page load (rubric: "proper loading states") -->
<div class="page-loader"></div>
<div class="app-container">
