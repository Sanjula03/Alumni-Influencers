<%- include('../partials/header') %>
<%- include('../partials/sidebar') %>

<div class="main-content with-sidebar">
  <div class="top-header animate-slide-up" style="margin-bottom: 2rem; display: flex; justify-content: space-between; align-items: center;">
    <div>
      <h1 style="font-size: 28px; font-weight: 900; letter-spacing: -0.05em; margin: 0;">Profile Studio</h1>
      <p style="color: var(--text-muted); margin-top: 4px; font-size: 14px; font-weight: 500;">Refine your professional narrative and global presence.</p>
    </div>
    <div style="display: flex; gap: 12px;">
      <a href="/dashboard" class="btn btn-outline" style="border-radius: 100px; padding: 10px 24px; font-weight: 700;">Discard</a>
      <button type="button" class="btn btn-primary" id="masterSaveBtn" style="border-radius: 100px; padding: 10px 32px; font-weight: 800; box-shadow: 0 10px 20px -5px rgba(0,0,0,0.2);">
        <%= profile && profile.id ? 'Sync Profile' : 'Create Profile' %>
      </button>
    </div>
  </div>

  <%- include('../partials/flashData') %>

  <!-- Modern Unified Studio Layout -->
  <div class="profile-studio-container card animate-slide-up" id="studioContainer">
    
    <!-- Left: Profile Summary (Fixed) -->
    <div class="studio-sidebar-left">
      <div id="studioPreviewAvatar" class="avatar-container">
        <% if (profile.profile_image) { %>
          <img src="<%= profile.profile_image %>" class="avatar-image">
        <% } else { %>
          <div class="avatar-fallback">
            <svg viewBox="0 0 24 24"><path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
          </div>
        <% } %>
      </div>
      <h4 class="sidebar-user-name"><%= profile.first_name %> <%= profile.last_name %></h4>
      <p class="sidebar-user-role">Professional Portfolio</p>
      
      <div class="sidebar-help-card">
        <div class="help-header">
          <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
          EXECUTIVE GUIDE
        </div>
        Complete each section to ensure your profile meets enterprise standards. High-quality imagery and detailed experience improve visibility.
      </div>
    </div>

    <!-- Right: Unified Workspace (Scrolling) -->
    <div class="studio-workspace" id="studioWorkspace">
      <form id="profileForm" enctype="multipart/form-data" class="workspace-padding">
        <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
        <button type="submit" style="display: none;" id="hiddenSubmitBtn"></button>
        
        <!-- Section: Basic Info -->
        <div class="studio-section">
          <div class="section-title-area">
            <div class="section-icon-box">
              <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
            </div>
            <h2>Core Identity</h2>
          </div>
          
          <div class="form-row-dual">
            <div class="input-group">
              <label>Given Name</label>
              <input type="text" id="firstName" name="firstName" value="<%= profile.first_name || '' %>" required class="professional-input">
            </div>
            <div class="input-group">
              <label>Surname</label>
              <input type="text" id="lastName" name="lastName" value="<%= profile.last_name || '' %>" required class="professional-input">
            </div>
          </div>
          <div class="input-group full-width">
            <label>LinkedIn Professional URL</label>
            <input type="url" id="linkedInUrl" name="linkedInUrl" value="<%= profile.linkedin_url || '' %>" placeholder="https://linkedin.com/in/username" class="professional-input">
          </div>
          <div class="form-row-dual">
            <div class="input-group">
              <label>Academic Programme</label>
              <div class="custom-select-wrapper">
                <input type="hidden" id="programme" name="programme" value="<%= profile.programme || '' %>">
                <div class="custom-select-trigger professional-input" style="display: flex; justify-content: space-between; align-items: center; padding: 16px 24px;">
                  <span><%= profile.programme || 'Select Programme' %></span>
                </div>
                <div class="custom-options">
                  <div class="custom-options-content">
                    <div class="custom-option <%= !profile.programme ? 'selected' : '' %>" data-value="">Select Programme</div>
                    <% const programmes = ['Computer Science', 'Business Management', 'Fine Arts', 'Mechanical Engineering', 'Data Science', 'Nursing']; %>
                    <% programmes.forEach(p => { %>
                      <div class="custom-option <%= profile.programme === p ? 'selected' : '' %>" data-value="<%= p %>"><%= p %></div>
                    <% }) %>
                  </div>
                </div>
              </div>
            </div>
            <div class="input-group">
              <label>Graduation Year</label>
              <div class="custom-select-wrapper">
                <input type="hidden" id="graduationYear" name="graduationYear" value="<%= profile.graduation_year || '' %>">
                <div class="custom-select-trigger professional-input" style="display: flex; justify-content: space-between; align-items: center; padding: 16px 24px;">
                  <span><%= profile.graduation_year || 'Select Year' %></span>
                </div>
                <div class="custom-options">
                  <div class="custom-options-content">
                    <div class="custom-option <%= !profile.graduation_year ? 'selected' : '' %>" data-value="">Select Year</div>
                    <% for(let y = 2026; y >= 1990; y--) { %>
                      <div class="custom-option <%= profile.graduation_year == y ? 'selected' : '' %>" data-value="<%= y %>"><%= y %></div>
                    <% } %>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <div class="input-group full-width">
            <label>Executive Summary / Biography</label>
            <textarea id="biography" name="biography" rows="6" class="professional-input text-area"><%= profile.biography || '' %></textarea>
          </div>
        </div>

        <!-- Section: Photo -->
        <div class="studio-section">
          <div class="section-title-area">
            <div class="section-icon-box">
              <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
            </div>
            <h2>Visual Presence</h2>
          </div>
          
          <div class="photo-upload-container">
            <div id="imagePreviewContainer" class="preview-frame">
              <% if (profile.profile_image) { %>
                <img src="<%= profile.profile_image %>" style="width: 100%; height: 100%; object-fit: cover;">
              <% } else { %>
                <div class="preview-placeholder">
                  <svg width="48" height="48" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
                </div>
              <% } %>
            </div>
            <div class="upload-text-area">
              <h3>Profile Headshot</h3>
              <p>Upload a high-resolution portrait. Optimal size: 500x500px.</p>
              <input type="file" id="profileImage" name="profileImage" accept="image/*" style="display: none;">
              <button type="button" class="btn btn-primary" id="uploadTriggerBtn" style="border-radius: 10px; padding: 10px 24px;">Upload Image</button>
            </div>
          </div>
        </div>

        <!-- Section: Experience -->
        <div class="studio-section">
          <div class="section-header-row">
            <div class="section-title-area">
              <div class="section-icon-box">
                <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
              </div>
              <h2>Career Milestones</h2>
            </div>
            <button type="button" class="btn btn-outline small-pill" id="addEmploymentBtn">+ Add Milestone</button>
          </div>
          <div id="employmentContainer" class="dynamic-rows-wrapper">
            <% if (profile.employmentHistory && profile.employmentHistory.length > 0) { %>
              <% profile.employmentHistory.forEach((emp, index) => { %>
                <div class="professional-row employment-row animate-fade-in">
                  <button type="button" class="row-remove-btn">✕</button>
                  <div class="row-field-grid">
                    <div class="input-group"><label>Organization</label><input type="text" class="e-company professional-input" value="<%= emp.company %>"></div>
                    <div class="input-group"><label>Designation</label><input type="text" class="e-role professional-input" value="<%= emp.role %>"></div>
                  </div>
                  <div class="row-field-footer">
                    <div class="input-group"><label>Start Date</label><input type="date" class="e-start professional-input" value="<%= emp.start_date ? emp.start_date.split('T')[0] : '' %>"></div>
                    <div class="input-group"><label>End Date</label><input type="date" class="e-end professional-input" value="<%= emp.end_date ? emp.end_date.split('T')[0] : '' %>" <%= emp.is_current ? 'disabled' : '' %>></div>
                    <div class="current-toggle-box"><input type="checkbox" class="e-current" <%= emp.is_current ? 'checked' : '' %>><label>ACTIVE</label></div>
                  </div>
                </div>
              <% }) %>
            <% } %>
          </div>
        </div>

        <!-- Section: Education -->
        <div class="studio-section">
          <div class="section-header-row">
            <div class="section-title-area">
              <div class="section-icon-box">
                <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14zm-4 6v-7.5l4-2.222"></path></svg>
              </div>
              <h2>Academic Credentials</h2>
            </div>
            <button type="button" class="btn btn-outline small-pill" id="addDegreeBtn">+ Add Credential</button>
          </div>
          <div id="degreeContainer" class="dynamic-rows-wrapper">
            <% if (profile.degrees && profile.degrees.length > 0) { %>
              <% profile.degrees.forEach((deg, index) => { %>
                <div class="professional-row degree-row animate-fade-in">
                  <button type="button" class="row-remove-btn">✕</button>
                  <div class="row-field-grid">
                    <div class="input-group"><label>Degree / Qualification</label><input type="text" class="d-name professional-input" value="<%= deg.name %>"></div>
                    <div class="input-group"><label>Institution</label><input type="text" class="d-institution professional-input" value="<%= deg.institution %>"></div>
                  </div>
                  <div class="row-field-footer">
                    <div class="input-group" style="flex: 2;"><label>Credential URL</label><input type="url" class="d-url professional-input" value="<%= deg.url %>"></div>
                    <div class="input-group" style="flex: 1;"><label>Completion Date</label><input type="date" class="d-date professional-input" value="<%= deg.completion_date ? deg.completion_date.split('T')[0] : '' %>"></div>
                  </div>
                </div>
              <% }) %>
            <% } %>
          </div>
        </div>

        <!-- Section: Certifications -->
        <div class="studio-section">
          <div class="section-header-row">
            <div class="section-title-area">
              <div class="section-icon-box">
                <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"></path></svg>
              </div>
              <h2>Professional Certifications</h2>
            </div>
            <button type="button" class="btn btn-outline small-pill" id="addCertBtn">+ Add Cert</button>
          </div>
          <div id="certContainer" class="dynamic-rows-wrapper">
            <% if (profile.certifications && profile.certifications.length > 0) { %>
              <% profile.certifications.forEach((cert, index) => { %>
                <div class="professional-row cert-row animate-fade-in">
                  <button type="button" class="row-remove-btn">✕</button>
                  <div class="row-field-grid">
                    <div class="input-group"><label>Certification Name</label><input type="text" class="c-name professional-input" value="<%= cert.name %>"></div>
                    <div class="input-group"><label>Issuing Body</label><input type="text" class="c-body professional-input" value="<%= cert.issuing_body %>"></div>
                  </div>
                  <div class="row-field-footer">
                    <div class="input-group" style="flex: 2;"><label>Validation URL</label><input type="url" class="c-url professional-input" value="<%= cert.url %>"></div>
                    <div class="input-group" style="flex: 1;"><label>Completion Date</label><input type="date" class="c-date professional-input" value="<%= cert.completion_date ? cert.completion_date.split('T')[0] : '' %>"></div>
                  </div>
                </div>
              <% }) %>
            <% } %>
          </div>
        </div>

        <!-- Section: Licences -->
        <div class="studio-section">
          <div class="section-header-row">
            <div class="section-title-area">
              <div class="section-icon-box">
                <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
              </div>
              <h2>Professional Licences</h2>
            </div>
            <button type="button" class="btn btn-outline small-pill" id="addLicenceBtn">+ Add Licence</button>
          </div>
          <div id="licenceContainer" class="dynamic-rows-wrapper">
            <% if (profile.licences && profile.licences.length > 0) { %>
              <% profile.licences.forEach((lic, index) => { %>
                <div class="professional-row licence-row animate-fade-in">
                  <button type="button" class="row-remove-btn">✕</button>
                  <div class="row-field-grid">
                    <div class="input-group"><label>Licence Title</label><input type="text" class="l-name professional-input" value="<%= lic.name %>"></div>
                    <div class="input-group"><label>Awarding Body</label><input type="text" class="l-body professional-input" value="<%= lic.awarding_body %>"></div>
                  </div>
                  <div class="row-field-footer">
                    <div class="input-group" style="flex: 2;"><label>Credential Link</label><input type="url" class="l-url professional-input" value="<%= lic.url %>"></div>
                    <div class="input-group" style="flex: 1;"><label>Issue Date</label><input type="date" class="l-date professional-input" value="<%= lic.completion_date ? lic.completion_date.split('T')[0] : '' %>"></div>
                  </div>
                </div>
              <% }) %>
            <% } %>
          </div>
        </div>

        <!-- Section: Courses -->
        <div class="studio-section no-border">
          <div class="section-header-row">
            <div class="section-title-area">
              <div class="section-icon-box">
                <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path></svg>
              </div>
              <h2>Specialized Courses</h2>
            </div>
            <button type="button" class="btn btn-outline small-pill" id="addCourseBtn">+ Add Course</button>
          </div>
          <div id="courseContainer" class="dynamic-rows-wrapper">
            <% if (profile.courses && profile.courses.length > 0) { %>
              <% profile.courses.forEach((course, index) => { %>
                <div class="professional-row course-row animate-fade-in">
                  <button type="button" class="row-remove-btn">✕</button>
                  <div class="row-field-grid">
                    <div class="input-group"><label>Course Title</label><input type="text" class="co-name professional-input" value="<%= course.name %>"></div>
                    <div class="input-group"><label>Provider</label><input type="text" class="co-provider professional-input" value="<%= course.provider %>"></div>
                  </div>
                  <div class="row-field-footer">
                    <div class="input-group" style="flex: 2;"><label>Course URL</label><input type="url" class="co-url professional-input" value="<%= course.url %>"></div>
                    <div class="input-group" style="flex: 1;"><label>Completion Date</label><input type="date" class="co-date professional-input" value="<%= course.completion_date ? course.completion_date.split('T')[0] : '' %>"></div>
                  </div>
                </div>
              <% }) %>
            <% } %>
          </div>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- STUDIO ENGINE: ROBUST EVENT DELEGATION -->
<script>
document.addEventListener('DOMContentLoaded', function() {
  console.log("Studio Engine Initializing...");

  // 1. MASTER SAVE BUTTON
  const masterSaveBtn = document.getElementById('masterSaveBtn');
  if (masterSaveBtn) {
    masterSaveBtn.addEventListener('click', function() {
      const hiddenBtn = document.getElementById('hiddenSubmitBtn');
      if (hiddenBtn) hiddenBtn.click();
    });
  }

  // 2. UPLOAD TRIGGER
  const uploadTriggerBtn = document.getElementById('uploadTriggerBtn');
  const profileImageInput = document.getElementById('profileImage');
  if (uploadTriggerBtn && profileImageInput) {
    uploadTriggerBtn.addEventListener('click', function() {
      profileImageInput.click();
    });

    // Smart URL helper for LinkedIn
    const linkedinInput = document.getElementById('linkedInUrl');
    if (linkedinInput) {
      linkedinInput.addEventListener('blur', function() {
        let val = this.value.trim();
        if (val && !val.startsWith('http://') && !val.startsWith('https://')) {
          this.value = 'https://' + val;
        }
      });
    }

    profileImageInput.addEventListener('change', function() {
      if (this.files && this.files[0]) {
        const reader = new FileReader();
        reader.onload = function(e) {
          const preview = document.getElementById('imagePreviewContainer');
          const studioPreview = document.getElementById('studioPreviewAvatar');
          if (preview) preview.innerHTML = '<img src="' + e.target.result + '" style="width: 100%; height: 100%; object-fit: cover;">';
          if (studioPreview) studioPreview.innerHTML = '<img src="' + e.target.result + '" style="width: 100%; height: 100%; object-fit: cover;">';
        };
        reader.readAsDataURL(this.files[0]);
      }
    });
  }

  // 3. DYNAMIC ROW ADDERS
  const addEmploymentBtn = document.getElementById('addEmploymentBtn');
  if (addEmploymentBtn) {
    addEmploymentBtn.addEventListener('click', function() {
      const container = document.getElementById('employmentContainer');
      const html = `
        <div class="professional-row employment-row animate-fade-in">
          <button type="button" class="row-remove-btn">✕</button>
          <div class="row-field-grid">
            <div class="input-group"><label>Organization</label><input type="text" class="e-company professional-input" placeholder="Company Name"></div>
            <div class="input-group"><label>Designation</label><input type="text" class="e-role professional-input" placeholder="Job Title"></div>
          </div>
          <div class="row-field-footer">
            <div class="input-group"><label>Start Date</label><input type="date" class="e-start professional-input"></div>
            <div class="input-group"><label>End Date</label><input type="date" class="e-end professional-input"></div>
            <div class="current-toggle-box"><input type="checkbox" class="e-current"><label>ACTIVE</label></div>
          </div>
        </div>`;
      container.insertAdjacentHTML('beforeend', html);
    });
  }

  const addDegreeBtn = document.getElementById('addDegreeBtn');
  if (addDegreeBtn) {
    addDegreeBtn.addEventListener('click', function() {
      const container = document.getElementById('degreeContainer');
      const html = `
        <div class="professional-row degree-row animate-fade-in">
          <button type="button" class="row-remove-btn">✕</button>
          <div class="row-field-grid">
            <div class="input-group"><label>Degree / Qualification</label><input type="text" class="d-name professional-input" placeholder="e.g. MBA"></div>
            <div class="input-group"><label>Institution</label><input type="text" class="d-institution professional-input" placeholder="University Name"></div>
          </div>
          <div class="row-field-footer">
            <div class="input-group" style="flex: 2;"><label>Credential URL</label><input type="url" class="d-url professional-input" placeholder="Link"></div>
            <div class="input-group" style="flex: 1;"><label>Completion Date</label><input type="date" class="d-date professional-input"></div>
          </div>
        </div>`;
      container.insertAdjacentHTML('beforeend', html);
    });
  }

  const addCertBtn = document.getElementById('addCertBtn');
  if (addCertBtn) {
    addCertBtn.addEventListener('click', function() {
      const container = document.getElementById('certContainer');
      const html = `
        <div class="professional-row cert-row animate-fade-in">
          <button type="button" class="row-remove-btn">✕</button>
          <div class="row-field-grid">
            <div class="input-group"><label>Certification Name</label><input type="text" class="c-name professional-input" placeholder="e.g. AWS Solutions Architect"></div>
            <div class="input-group"><label>Issuing Body</label><input type="text" class="c-body professional-input" placeholder="e.g. Amazon Web Services"></div>
          </div>
          <div class="row-field-footer">
            <div class="input-group" style="flex: 2;"><label>Validation URL</label><input type="url" class="c-url professional-input" placeholder="Credential link"></div>
            <div class="input-group" style="flex: 1;"><label>Completion Date</label><input type="date" class="c-date professional-input"></div>
          </div>
        </div>`;
      container.insertAdjacentHTML('beforeend', html);
    });
  }

  const addLicenceBtn = document.getElementById('addLicenceBtn');
  if (addLicenceBtn) {
    addLicenceBtn.addEventListener('click', function() {
      const container = document.getElementById('licenceContainer');
      const html = `
        <div class="professional-row licence-row animate-fade-in">
          <button type="button" class="row-remove-btn">✕</button>
          <div class="row-field-grid">
            <div class="input-group"><label>Licence Title</label><input type="text" class="l-name professional-input" placeholder="e.g. Registered Architect"></div>
            <div class="input-group"><label>Awarding Body</label><input type="text" class="l-body professional-input" placeholder="e.g. AIA"></div>
          </div>
          <div class="row-field-footer">
            <div class="input-group" style="flex: 2;"><label>Credential Link</label><input type="url" class="l-url professional-input" placeholder="Link"></div>
            <div class="input-group" style="flex: 1;"><label>Issue Date</label><input type="date" class="l-date professional-input"></div>
          </div>
        </div>`;
      container.insertAdjacentHTML('beforeend', html);
    });
  }

  const addCourseBtn = document.getElementById('addCourseBtn');
  if (addCourseBtn) {
    addCourseBtn.addEventListener('click', function() {
      const container = document.getElementById('courseContainer');
      const html = `
        <div class="professional-row course-row animate-fade-in">
          <button type="button" class="row-remove-btn">✕</button>
          <div class="row-field-grid">
            <div class="input-group"><label>Course Title</label><input type="text" class="co-name professional-input" placeholder="e.g. Leadership Masterclass"></div>
            <div class="input-group"><label>Provider</label><input type="text" class="co-provider professional-input" placeholder="e.g. Harvard Online"></div>
          </div>
          <div class="row-field-footer">
            <div class="input-group" style="flex: 2;"><label>Course URL</label><input type="url" class="co-url professional-input" placeholder="Link"></div>
            <div class="input-group" style="flex: 1;"><label>Completion Date</label><input type="date" class="co-date professional-input"></div>
          </div>
        </div>`;
      container.insertAdjacentHTML('beforeend', html);
    });
  }

  // 4. EVENT DELEGATION FOR DELETE & TOGGLE
  document.addEventListener('click', function(e) {
    // Row Removal
    if (e.target.classList.contains('row-remove-btn')) {
      const row = e.target.closest('.professional-row');
      if (row) {
        row.style.opacity = '0';
        row.style.transform = 'translateY(-10px)';
        row.style.transition = 'all 0.3s ease';
        setTimeout(function() { row.remove(); }, 300);
      }
    }

    // Toggle End Date
    if (e.target.classList.contains('e-current')) {
      const row = e.target.closest('.professional-row');
      const endInput = row.querySelector('.e-end');
      if (endInput) {
        endInput.disabled = e.target.checked;
        if (e.target.checked) endInput.value = '';
      }
    }
  });

  // 5. AJAX FORM SUBMISSION
  const profileForm = document.getElementById('profileForm');
  if (profileForm) {
    profileForm.addEventListener('submit', async function(e) {
      e.preventDefault();
      const saveBtn = document.getElementById('masterSaveBtn');
      const originalText = saveBtn.innerHTML;
      saveBtn.innerHTML = 'Syncing...';
      saveBtn.disabled = true;

      const formData = new FormData();
      
      // CSRF Protection via Header (Best for Multipart/Form-Data)
      const csrfToken = document.querySelector('input[name="_csrf"]')?.value || '';

      formData.append('firstName', document.getElementById('firstName').value);
      formData.append('lastName', document.getElementById('lastName').value);
      formData.append('linkedInUrl', document.getElementById('linkedInUrl').value);
      formData.append('biography', document.getElementById('biography').value);
      formData.append('programme', document.getElementById('programme').value);
      formData.append('graduationYear', document.getElementById('graduationYear').value);

      const imageFile = document.getElementById('profileImage').files[0];
      if (imageFile) formData.append('profileImage', imageFile);

      const employment = [];
      document.querySelectorAll('.employment-row').forEach(row => {
        const company = row.querySelector('.e-company').value;
        if (company) {
          employment.push({
            company: company,
            role: row.querySelector('.e-role').value,
            startDate: row.querySelector('.e-start').value,
            endDate: row.querySelector('.e-end').value,
            isCurrent: row.querySelector('.e-current').checked
          });
        }
      });
      formData.append('employmentHistory', JSON.stringify(employment));

      const degrees = [];
      document.querySelectorAll('.degree-row').forEach(row => {
        const name = row.querySelector('.d-name').value;
        if (name) {
          degrees.push({
            name: name,
            institution: row.querySelector('.d-institution').value,
            url: row.querySelector('.d-url').value,
            completionDate: row.querySelector('.d-date').value
          });
        }
      });
      formData.append('degrees', JSON.stringify(degrees));

      const certifications = [];
      document.querySelectorAll('.cert-row').forEach(row => {
        const name = row.querySelector('.c-name').value;
        if (name) {
          certifications.push({
            name: name,
            issuingBody: row.querySelector('.c-body').value,
            url: row.querySelector('.c-url').value,
            completionDate: row.querySelector('.c-date').value
          });
        }
      });
      formData.append('certifications', JSON.stringify(certifications));

      const licences = [];
      document.querySelectorAll('.licence-row').forEach(row => {
        const name = row.querySelector('.l-name').value;
        if (name) {
          licences.push({
            name: name,
            awardingBody: row.querySelector('.l-body').value,
            url: row.querySelector('.l-url').value,
            completionDate: row.querySelector('.l-date').value
          });
        }
      });
      formData.append('licences', JSON.stringify(licences));

      const courses = [];
      document.querySelectorAll('.course-row').forEach(row => {
        const name = row.querySelector('.co-name').value;
        if (name) {
          courses.push({
            name: name,
            provider: row.querySelector('.co-provider').value,
            url: row.querySelector('.co-url').value,
            completionDate: row.querySelector('.co-date').value
          });
        }
      });
      formData.append('courses', JSON.stringify(courses));

      try {
        const res = await fetch('/profile', { 
          method: 'POST', 
          body: formData,
          headers: {
            'X-CSRF-Token': csrfToken
          }
        });
        const data = await res.json();
        if (data.success) {
          saveBtn.innerHTML = '✅ Synced';
          setTimeout(() => window.location.reload(), 1000);
        } else {
          alert('Error: ' + data.error);
          saveBtn.innerHTML = originalText;
          saveBtn.disabled = false;
        }
      } catch (err) {
        alert('Synchronization error.');
        saveBtn.innerHTML = originalText;
        saveBtn.disabled = false;
      }
    });
  }
});
</script>

