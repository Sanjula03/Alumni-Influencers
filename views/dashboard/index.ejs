<%- include('../partials/header') %>
<%- include('../partials/sidebar') %>

<style>
  /* Premium Dashboard Enhancements */
  .stats-card {
    transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }
  .stats-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 30px 60px -12px rgba(99, 102, 241, 0.15);
  }
  
  .deal-card {
    background: white;
    border-radius: 24px;
    padding: 24px;
    border: 1px solid #f1f5f9;
    display: flex;
    justify-content: space-between;
    align-items: center;
    transition: all 0.3s;
  }
  .deal-card:hover {
    border-color: #e2e8f0;
    box-shadow: 0 10px 25px -5px rgba(0,0,0,0.05);
  }

  /* Custom Action Modal (Confirmation) */
  .action-modal-overlay {
    position: fixed;
    top: 0; left: 0; right: 0; bottom: 0;
    background: rgba(15, 23, 42, 0.6);
    backdrop-filter: blur(8px);
    z-index: 2000000;
    display: none;
    align-items: center;
    justify-content: center;
  }
  .action-modal {
    background: white;
    padding: 40px;
    border-radius: 32px;
    max-width: 400px;
    width: 90%;
    text-align: center;
    box-shadow: 0 40px 80px -20px rgba(0,0,0,0.3);
  }
</style>

<!-- Custom Confirmation Modal -->
<div id="confirmModal" class="action-modal-overlay">
  <div class="action-modal animate-slide-up">
    <div style="width: 64px; height: 64px; background: #fff7ed; border-radius: 20px; display: flex; align-items: center; justify-content: center; margin: 0 auto 24px;">
      <svg width="32" height="32" fill="none" stroke="#f97316" stroke-width="2.5" viewBox="0 0 24 24"><path d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
    </div>
    <h3 style="font-size: 22px; font-weight: 800; color: #0f172a; margin-bottom: 12px; letter-spacing: -0.02em;">Accept Endorsement?</h3>
    <p style="color: #64748b; font-size: 15px; line-height: 1.6; margin-bottom: 32px;">This will officially accept the sponsorship funds and add them to your bidding power.</p>
    <div style="display: flex; gap: 12px;">
      <button id="cancelActionBtn" class="btn" style="flex: 1; padding: 16px; border-radius: 16px; background: #f1f5f9; color: #475569; font-weight: 700; border: none; cursor: pointer;">Cancel</button>
      <button id="confirmActionBtn" class="btn btn-primary" style="flex: 1; padding: 16px; border-radius: 16px; font-weight: 700;">Accept</button>
    </div>
  </div>
</div>

<div class="main-content with-sidebar">
  <div class="dashboard-hero animate-slide-up" style="background: white; border: 1px solid #f1f5f9; border-radius: 32px; padding: 48px; margin-bottom: 40px; display: flex; justify-content: space-between; align-items: center; box-shadow: 0 20px 40px -10px rgba(0,0,0,0.03); position: relative; overflow: hidden;">
    <div style="position: absolute; top: -100px; right: -100px; width: 300px; height: 300px; background: linear-gradient(135deg, rgba(99,102,241,0.05) 0%, rgba(168,85,247,0.05) 100%); border-radius: 50%;"></div>
    <div style="z-index: 1;">
      <h1 style="font-size: 36px; font-weight: 900; letter-spacing: -0.04em; margin: 0; color: #0f172a;">Welcome back, <%= user.email.split('@')[0] %></h1>
      <p style="color: #64748b; margin-top: 10px; font-size: 17px; font-weight: 500;">Your alumni network is active with <span style="color: #6366f1; font-weight: 700;">12 new updates</span> since you last logged in.</p>
    </div>
    <div style="display: flex; gap: 16px; z-index: 1;">
      <a href="/dashboard/profile" class="btn btn-outline" style="padding: 14px 28px; border-radius: 18px; font-weight: 700; background: white; border: 2px solid #f1f5f9;">
        <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
        Edit Profile
      </a>
      <a href="/dashboard/alumni" class="btn btn-primary" style="padding: 14px 28px; border-radius: 18px; font-weight: 800; background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%); box-shadow: 0 15px 30px -10px rgba(99,102,241,0.4);">
        <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
        Explore Directory
      </a>
    </div>
  </div>

  <%- include('../partials/flashData') %>

  <!-- Metrics Grid -->
  <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 24px; margin-bottom: 40px;" class="animate-slide-up">
    
    <div class="card stats-card" style="margin-bottom: 0; border-radius: 28px; padding: 32px; border-top: 5px solid #6366f1;">
      <div style="font-size:11px; font-weight:800; color:#94a3b8; text-transform:uppercase; letter-spacing:0.15em; margin-bottom: 16px;">Alumni Profiles</div>
      <div style="font-size: 42px; font-weight: 900; letter-spacing: -0.03em; color: #0f172a;"><%= metrics.totalAlumni %></div>
      <div style="margin-top: 12px; display: flex; align-items: center; gap: 6px;">
        <span style="width: 8px; height: 8px; background: #10b981; border-radius: 50%;"></span>
        <span style="font-size: 13px; color: #10b981; font-weight: 700;">Active in Network</span>
      </div>
    </div>

    <div class="card stats-card" style="margin-bottom: 0; border-radius: 28px; padding: 32px; border-top: 5px solid #10b981;">
      <div style="font-size:11px; font-weight:800; color:#94a3b8; text-transform:uppercase; letter-spacing:0.15em; margin-bottom: 16px;">Verified Users</div>
      <div style="font-size: 42px; font-weight: 900; letter-spacing: -0.03em; color: #0f172a;"><%= metrics.activeUsers %></div>
      <div style="margin-top: 12px; font-size: 13px; color: #64748b; font-weight: 600;">Security Cleared</div>
    </div>

    <div class="card stats-card" style="margin-bottom: 0; border-radius: 28px; padding: 32px; border-top: 5px solid #f97316;">
      <div style="font-size:11px; font-weight:800; color:#94a3b8; text-transform:uppercase; letter-spacing:0.15em; margin-bottom: 16px;">Total Degrees</div>
      <div style="font-size: 42px; font-weight: 900; letter-spacing: -0.03em; color: #0f172a;"><%= metrics.totalDegrees %></div>
      <div style="margin-top: 12px; font-size: 13px; color: #f97316; font-weight: 700;">Academic Excellence</div>
    </div>

    <div class="card stats-card" style="margin-bottom: 0; border-radius: 28px; padding: 32px; border-top: 5px solid #ec4899;">
      <div style="font-size:11px; font-weight:800; color:#94a3b8; text-transform:uppercase; letter-spacing:0.15em; margin-bottom: 16px;">Certifications</div>
      <div style="font-size: 42px; font-weight: 900; letter-spacing: -0.03em; color: #0f172a;"><%= metrics.totalCertifications %></div>
      <div style="margin-top: 12px; font-size: 13px; color: #ec4899; font-weight: 700;">Skill Upgrades</div>
    </div>
  </div>

  <% if (user.role === 'alumnus' && pendingOffers && pendingOffers.length > 0) { %>
    <!-- Sponsorship Inbox -->
    <div class="card animate-slide-up" style="border: none; background: linear-gradient(135deg, #fff7ed 0%, #fff 100%); border-radius: 32px; padding: 40px; margin-bottom: 40px; border: 1px solid #ffedd5;">
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 32px;">
        <h3 style="margin: 0; font-size: 22px; font-weight: 900; display: flex; align-items: center; gap: 14px; color: #9a3412;">
          <div style="width: 44px; height: 44px; background: #ffedd5; border-radius: 14px; display: flex; align-items: center; justify-content: center;">
            <svg width="24" height="24" fill="none" stroke="#f97316" stroke-width="2.5" viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4m4-5l5 5 5-5m-5 5V3"></path></svg>
          </div>
          Sponsorship Inbox
        </h3>
        <div style="background: #ea580c; color: #fff; font-size: 11px; font-weight: 900; padding: 6px 14px; border-radius: 100px; text-transform: uppercase; letter-spacing: 0.05em;"><%= pendingOffers.length %> PENDING</div>
      </div>
      <div style="display: grid; gap: 20px;">
        <% pendingOffers.forEach(offer => { %>
          <div class="deal-card">
            <div style="display: flex; align-items: center; gap: 24px;">
              <div style="width: 56px; height: 56px; background: #fff; border-radius: 18px; border: 2px solid #f1f5f9; display: flex; align-items: center; justify-content: center; font-size: 24px;">💎</div>
              <div>
                <div style="font-weight: 900; color: #0f172a; font-size: 18px; letter-spacing: -0.01em;">£<%= parseFloat(offer.amount).toLocaleString() %> <span style="font-size: 14px; color: #94a3b8; font-weight: 600; margin-left: 4px;">Endorsement</span></div>
                <div style="font-size: 14px; color: #64748b; margin-top: 4px; font-weight: 500;">
                  From <span style="font-weight: 700; color: #6366f1;"><%= offer.sponsor.email.split('@')[0] %></span> for your <span style="color: #0f172a; font-weight: 700;"><%= offer.credential_type %></span>
                </div>
              </div>
            </div>
            <button class="btn btn-primary accept-offer-btn" data-id="<%= offer.id %>" style="padding: 16px 32px; border-radius: 16px; font-size: 14px; font-weight: 800; background: #0f172a; box-shadow: 0 10px 20px rgba(0,0,0,0.1);">Accept Offer</button>
          </div>
        <% }) %>
      </div>
    </div>

    <script>
      (function() {
        const confirmModal = document.getElementById('confirmModal');
        const cancelBtn = document.getElementById('cancelActionBtn');
        const confirmActionBtn = document.getElementById('confirmActionBtn');
        let currentOfferId = null;
        let currentBtn = null;

        document.addEventListener('click', function(e) {
          const btn = e.target.closest('.accept-offer-btn');
          if (!btn) return;
          currentOfferId = btn.dataset.id;
          currentBtn = btn;
          confirmModal.style.display = 'flex';
        });

        cancelBtn.addEventListener('click', () => {
          confirmModal.style.display = 'none';
        });

        confirmActionBtn.addEventListener('click', async function() {
          confirmModal.style.display = 'none';
          if (!currentOfferId || !currentBtn) return;

          currentBtn.disabled = true;
          currentBtn.textContent = 'Processing...';
          currentBtn.style.opacity = '0.7';

          try {
            const response = await fetch(`/sponsorship/accept/${currentOfferId}`, {
              method: 'POST',
              headers: { 
                'Content-Type': 'application/json',
                'x-csrf-token': '<%= csrfToken %>' 
              }
            });
            
            const result = await response.json();
            if (result.success) {
              if (window.showToast) {
                window.showToast('Success!', 'Funds added to your bidding power.', 'success');
              }
              setTimeout(() => location.reload(), 1500);
            } else {
              alert('Error: ' + result.error);
              currentBtn.disabled = false;
              currentBtn.textContent = 'Accept Offer';
              currentBtn.style.opacity = '1';
            }
          } catch (err) {
            alert('Network error.');
            currentBtn.disabled = false;
            currentBtn.textContent = 'Accept Offer';
            currentBtn.style.opacity = '1';
          }
        });
      })();
    </script>
  <% } %>

  <div style="display: grid; grid-template-columns: 2fr 1.2fr; gap: 32px; margin-bottom: 40px;" class="animate-slide-up">
    <!-- Quick Insights -->
    <div class="card" style="margin-bottom: 0; border-radius: 32px; padding: 40px; display: flex; flex-direction: column; justify-content: center; border: 1px solid #f1f5f9;">
      <div style="margin-bottom: 32px;">
        <h3 style="margin: 0 0 12px; font-size: 24px; font-weight: 900; color: #0f172a; letter-spacing: -0.02em;">Global Marketplace Insights</h3>
        <p style="color: #64748b; font-size: 16px; line-height: 1.7; font-weight: 500;">Access real-time analytics to discover emerging skills gaps and employment trends. Leverage the alumni network to position yourself as a top influencer.</p>
      </div>
      <div style="display: flex; gap: 16px;">
        <a href="/analytics/charts" class="btn btn-primary" style="padding: 16px 32px; border-radius: 16px; font-weight: 800; background: #6366f1;">View Analytics Hub</a>
        <a href="/dashboard/alumni" class="btn btn-outline" style="padding: 16px 32px; border-radius: 16px; font-weight: 800; border: 2px solid #f1f5f9;">Explore Network</a>
      </div>
    </div>

    <!-- Featured Today -->
    <div class="card" style="margin-bottom: 0; background: #0f172a; color: #fff; border: none; border-radius: 32px; position: relative; overflow: hidden; padding: 40px; box-shadow: 0 30px 60px -15px rgba(15,23,42,0.3);">
      <div style="position: absolute; top: -50px; right: -50px; width: 200px; height: 200px; background: linear-gradient(135deg, rgba(255,255,255,0.1) 0%, transparent 100%); border-radius: 50%;"></div>
      <div style="font-size:11px; font-weight:900; color:rgba(255,255,255,0.4); text-transform:uppercase; letter-spacing:0.25em; margin-bottom: 32px;">Alumnus of the Week</div>
      
      <% if (featuredProfile) { %>
        <div style="display: flex; align-items: center; gap: 24px; margin-bottom: 32px;">
          <img src="<%= featuredProfile.profile_image || 'https://ui-avatars.com/api/?name=' + featuredProfile.first_name + '+' + featuredProfile.last_name + '&background=6366f1&color=fff' %>" 
               style="width: 72px; height: 72px; border-radius: 24px; border: 3px solid rgba(255,255,255,0.1); object-fit: cover; box-shadow: 0 10px 20px rgba(0,0,0,0.2);">
          <div>
            <div style="font-weight: 900; font-size: 20px; letter-spacing: -0.01em;"><%= featuredProfile.first_name %> <%= featuredProfile.last_name %></div>
            <div style="font-size: 14px; color: rgba(255,255,255,0.5); margin-top: 4px; font-weight: 600;"><%= featuredProfile.graduation_year %> • <%= featuredProfile.programme %></div>
          </div>
        </div>
        <p style="font-size: 15px; color: rgba(255,255,255,0.6); line-height: 1.8; margin-bottom: 32px; font-weight: 500;">
          <%= featuredProfile.biography ? featuredProfile.biography.substring(0, 110) + '...' : 'Pioneering new standards in the professional network through consistent excellence and mentorship.' %>
        </p>
        <a href="/dashboard/alumni" style="text-decoration: none; font-weight: 800; color: #fff; font-size: 14px; display: flex; align-items: center; gap: 10px; transition: all 0.2s;">
          View Full Profile <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M13 7l5 5m0 0l-5 5m5-5H6"></path></svg>
        </a>
      <% } else { %>
        <div style="padding: 48px 0; text-align: center; border: 2px dashed rgba(255,255,255,0.1); border-radius: 24px; display: flex; flex-direction: column; align-items: center; gap: 16px;">
          <div style="font-size: 14px; color: rgba(255,255,255,0.3); font-weight: 700; letter-spacing: 0.05em;">NETWORK ACTIVITY...</div>
        </div>
      <% } %>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
