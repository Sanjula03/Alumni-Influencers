<%- include('../partials/header') %>
<%- include('../partials/sidebar') %>

<div class="main-content with-sidebar">
  <div class="top-header">
    <h2>Dashboard Overview</h2>
    <div>Welcome, <strong><%= user.email %></strong></div>
  </div>

  <%- include('../partials/flashData') %>

  <div class="metrics-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; margin-bottom: 30px;">
    
    <div class="card" style="margin-bottom: 0;">
      <h3 style="margin-top:0; color:var(--text-muted); font-size:14px;">Total Alumni Profiles</h3>
      <div style="font-size: 32px; font-weight: bold; color: var(--primary-color);"><%= metrics.totalAlumni %></div>
    </div>

    <div class="card" style="margin-bottom: 0;">
      <h3 style="margin-top:0; color:var(--text-muted); font-size:14px;">Active Users</h3>
      <div style="font-size: 32px; font-weight: bold; color: var(--success);"><%= metrics.activeUsers %></div>
    </div>

    <div class="card" style="margin-bottom: 0;">
      <h3 style="margin-top:0; color:var(--text-muted); font-size:14px;">Total Degrees Logged</h3>
      <div style="font-size: 32px; font-weight: bold; color: #8b5cf6;"><%= metrics.totalDegrees %></div>
    </div>

    <div class="card" style="margin-bottom: 0;">
      <h3 style="margin-top:0; color:var(--text-muted); font-size:14px;">Total Certifications</h3>
      <div style="font-size: 32px; font-weight: bold; color: var(--warning);"><%= metrics.totalCertifications %></div>
    </div>

  </div>

  <div class="card">
    <h3>Quick Actions</h3>
    <p>Use the sidebar to navigate to the detailed analysis pages.</p>
    <a href="/analytics/charts" class="btn btn-primary">View Full Analytics</a>
    <a href="/dashboard/alumni" class="btn" style="background:var(--border-color); color:var(--text-main);">Browse Alumni Search</a>
  </div>
</div>

<%- include('../partials/footer') %>
