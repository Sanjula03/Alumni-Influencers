<%- include('../partials/header') %>
<%- include('../partials/sidebar') %>

<style>
  /* Bidding Studio: Midnight & Slate Integration */
  .bidding-workspace { 
    background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%); 
    min-height: 100vh;
    padding-bottom: 80px;
  }
  
  .premium-metric-grid { 
    display: grid; 
    grid-template-columns: repeat(4, 1fr); 
    gap: 24px; 
    margin-bottom: 40px; 
  }

  .metric-tile {
    background: linear-gradient(to bottom right, #ffffff 0%, #fcfdfe 100%);
    border: 1px solid #e2e8f0;
    border-radius: 32px;
    padding: 32px;
    text-align: center;
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.05);
    transition: transform 0.3s ease;
  }
  .metric-tile:hover { transform: translateY(-4px); }
  .metric-label { font-size: 11px; font-weight: 900; color: #64748b; text-transform: uppercase; letter-spacing: 0.15em; margin-bottom: 16px; }
  .metric-value { font-size: 32px; font-weight: 900; color: #0f172a; letter-spacing: -0.04em; }
  .metric-subtext { font-size: 12px; color: #94a3b8; font-weight: 700; margin-top: 8px; }

  .bidding-card {
    background: linear-gradient(to bottom right, #ffffff 0%, #fcfdfe 100%);
    border-radius: 40px;
    padding: 48px;
    box-shadow: 
      0 20px 25px -5px rgba(0, 0, 0, 0.05),
      inset 0 0 0 1px rgba(255, 255, 255, 0.8);
    border: 1px solid #e2e8f0;
    margin-bottom: 32px;
  }

  .bidding-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 48px; }
  .bidding-header h1 { font-size: 32px; font-weight: 900; color: #0f172a; letter-spacing: -0.05em; margin: 0; }
  .bidding-header p { color: #64748b; font-size: 16px; margin-top: 8px; }

  .live-status-pill {
    padding: 12px 24px;
    border-radius: 100px;
    font-size: 13px;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  .status-winning { background: #f0fdf4; color: #166534; border: 1px solid #bbf7d0; }
  .status-losing { background: #fff1f2; color: #9f1239; border: 1px solid #fecdd3; }
  .status-pending { background: #fffbeb; color: #92400e; border: 1px solid #fef3c7; }

  .professional-input { 
    width: 100%; 
    padding: 18px 24px; 
    border: 1px solid #e2e8f0; 
    background: #f8fafc; 
    border-radius: 20px; 
    font-size: 16px; 
    font-weight: 700; 
    color: #0f172a;
    outline: none; 
    transition: all 0.2s; 
    box-sizing: border-box; 
  }
  .professional-input:focus { border-color: #38bdf8; background: #fff; box-shadow: 0 0 0 5px rgba(56, 189, 248, 0.1); }

  .history-table { width: 100%; border-collapse: separate; border-spacing: 0; margin-top: 24px; }
  .history-table th { text-align: left; padding: 20px 24px; font-size: 11px; font-weight: 900; color: #64748b; text-transform: uppercase; letter-spacing: 0.15em; border-bottom: 1px solid #e2e8f0; }
  .history-table td { padding: 24px; font-size: 15px; color: #0f172a; font-weight: 600; border-bottom: 1px solid #f1f5f9; }
  .history-table tr:last-child td { border-bottom: none; }

  .bonus-badge {
    background: #0f172a;
    color: #38bdf8;
    font-size: 9px;
    font-weight: 900;
    padding: 4px 10px;
    border-radius: 100px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-left: 8px;
  }
</style>

<div class="main-content with-sidebar bidding-workspace">
  <div class="workspace-padding" style="max-width: 1100px; margin: 0 auto;">
    
    <div class="bidding-header animate-fade-in">
      <div>
        <h1>Blind Bidding System</h1>
        <p>Strategic placement for your "Alumnus of the Day" showcase.</p>
      </div>
      <div style="background: #fff; padding: 12px 24px; border-radius: 20px; border: 1px solid #e2e8f0; font-size: 14px; font-weight: 900; display: flex; align-items: center; gap: 12px; box-shadow: 0 4px 10px rgba(0,0,0,0.03);">
        <span style="width: 10px; height: 10px; background: #22c55e; border-radius: 50%; box-shadow: 0 0 10px rgba(34, 197, 94, 0.5);"></span>
        <span style="color: #64748b; font-size: 11px; text-transform: uppercase; letter-spacing: 0.1em;">Global Time</span>
        <span style="color: #0f172a;"><%= today %></span>
      </div>
    </div>

    <%- include('../partials/flashData') %>

    <!-- Metric Dashboard -->
    <div class="premium-metric-grid animate-fade-in" style="animation-delay: 0.1s;">
      <div class="metric-tile">
        <div class="metric-label">Sponsorship Fund</div>
        <div class="metric-value">£<%= parseFloat(totalSponsorship).toFixed(2) %></div>
        <div class="metric-subtext">Total Budget from Endorsements</div>
      </div>

      <div class="metric-tile">
        <div class="metric-label">Current Standing</div>
        <div style="margin-top: 12px;">
          <% if(!todaysBid) { %>
            <span class="live-status-pill status-pending">No Active Bid</span>
          <% } else if(todaysBid.status === 'pending' && bidStatus === 'winning') { %>
            <span class="live-status-pill status-winning">🏆 Winning</span>
          <% } else if(todaysBid.status === 'pending' && bidStatus === 'losing') { %>
            <span class="live-status-pill status-losing">⚠️ Outbid</span>
          <% } else if(todaysBid.status === 'won') { %>
            <span class="live-status-pill status-winning">🎉 Won Slot</span>
          <% } else if(todaysBid.status === 'lost') { %>
            <span class="live-status-pill status-losing">Final: Lost</span>
          <% } %>
        </div>
        <div class="metric-subtext">Real-time status tracking</div>
      </div>

      <div class="metric-tile">
        <div class="metric-label">Active Competition</div>
        <div class="metric-value"><%= totalBiddersToday %></div>
        <div class="metric-subtext">Participants today</div>
      </div>

      <div class="metric-tile">
        <div class="metric-label">Monthly Wins</div>
        <div class="metric-value"><%= monthlyWins %> <span style="font-size: 18px; color: #94a3b8; font-weight: 500;">/ <%= maxWins %></span></div>
        <div class="metric-subtext">
          Available: <%= remainingSlots %>
          <% if(attended) { %><span class="bonus-badge">Event Bonus Active</span><% } %>
        </div>
      </div>
    </div>

    <div style="display:grid; grid-template-columns: 1fr 1fr; gap:32px; margin-bottom:40px;" class="animate-fade-in" style="animation-delay: 0.2s;">
      
      <!-- Bidding Interface -->
      <div class="bidding-card" style="margin-bottom: 0;">
        <div class="section-title-area" style="margin-bottom: 24px;">
          <div class="section-icon-box" style="width: 36px; height: 36px; border-radius: 10px;">
            <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.407 2.633 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.407-2.633-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
          </div>
          <h2 style="font-size: 20px; font-weight: 900; margin: 0; letter-spacing: -0.04em;">
            <% if(todaysBid && todaysBid.status === 'pending') { %>
              Increase Bid
            <% } else if(!todaysBid) { %>
              Place Bid
            <% } else { %>
              Auction Closed
            <% } %>
          </h2>
        </div>

        <% if(!todaysBid || todaysBid.status === 'pending') { %>
          <% if(remainingSlots <= 0) { %>
            <div style="background: #fff1f2; border: 1px solid #fecdd3; padding: 24px; border-radius: 20px; color: #9f1239; font-size: 14px; font-weight: 700;">
              Maximum monthly limit of <%= maxWins %> wins reached.
            </div>
          <% } else { %>
            <p style="color: #64748b; font-size: 14px; line-height: 1.6; margin-bottom: 32px;">
              <% if(todaysBid) { %>
                Your current position is secured at <strong>£<%= parseFloat(todaysBid.amount).toFixed(2) %></strong>. You may increase this amount to improve your win probability.
              <% } else { %>
                Enter your sealed bid amount. The highest bidder at **6:00 PM** will be featured globally across the platform tomorrow.
              <% } %>
            </p>

            <form action="/bids/place" method="POST">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <div style="display:flex; flex-direction: column; gap:20px;">
                <div class="input-group">
                  <label>Investment Amount (GBP)</label>
                  <div style="position: relative;">
                    <span style="position: absolute; left: 24px; top: 50%; transform: translateY(-50%); font-weight: 900; color: #94a3b8;">£</span>
                    <input type="number" name="amount" step="0.01" min="<%= todaysBid ? (parseFloat(todaysBid.amount) + 0.01).toFixed(2) : '0.01' %>" 
                           placeholder="<%= todaysBid ? (parseFloat(todaysBid.amount) + 0.01).toFixed(2) : '0.00' %>" required 
                           class="professional-input" style="padding-left: 44px;">
                  </div>
                </div>
                <button type="submit" class="btn btn-primary" style="width: 100%; padding: 20px; border-radius: 20px; font-size: 15px; letter-spacing: 0;">
                  <%= todaysBid ? 'Secure Increased Bid' : 'Confirm & Place Bid' %>
                </button>
              </div>
            </form>

            <% if(todaysBid && todaysBid.status === 'pending') { %>
              <form action="/bids/cancel" method="POST" style="margin-top:16px;" onsubmit="return confirm('Withdraw current bid?');">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <button type="submit" style="background: none; border: none; color: #94a3b8; font-size: 12px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.1em; cursor: pointer; width: 100%; text-align: center;">Withdraw Active Bid</button>
              </form>
            <% } %>
          <% } %>
        <% } else { %>
          <div style="background: #f8fafc; border: 1px solid #e2e8f0; padding: 24px; border-radius: 20px; text-align: center;">
            <div style="font-size: 11px; font-weight: 900; color: #64748b; text-transform: uppercase; letter-spacing: 0.15em; margin-bottom: 8px;">Final Resolution</div>
            <div style="font-size: 20px; font-weight: 900; color: <%= todaysBid.status === 'won' ? '#22c55e' : '#ef4444' %>;">
              <%= todaysBid.status.toUpperCase() %>
            </div>
          </div>
        <% } %>
      </div>

      <!-- Slot Intelligence -->
      <div class="bidding-card" style="margin-bottom: 0;">
        <div class="section-title-area" style="margin-bottom: 24px;">
          <div class="section-icon-box" style="width: 36px; height: 36px; border-radius: 10px;">
            <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
          </div>
          <h2 style="font-size: 20px; font-weight: 900; margin: 0; letter-spacing: -0.04em;">Tomorrow's Slot</h2>
        </div>
        
        <div style="margin-bottom: 24px;">
          <div style="font-size: 11px; font-weight: 900; color: #64748b; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 8px;">Reserved For</div>
          <div style="font-size: 18px; font-weight: 900; color: #0f172a;"><%= tomorrowSlot.date %></div>
        </div>

        <% if(tomorrowSlot.status === 'taken') { %>
          <div style="background: linear-gradient(to right, #f0fdf4, #ffffff); border-left: 4px solid #22c55e; padding: 24px; border-radius: 16px;">
            <div style="font-size: 10px; font-weight: 900; color: #166534; text-transform: uppercase; letter-spacing: 0.1em;">System Status</div>
            <div style="font-size: 16px; font-weight: 900; color: #15803d; margin-top: 4px;">✓ Slot Finalized</div>
            <div style="font-size: 14px; color: #166534; margin-top: 8px; font-weight: 700;">Winner: <span style="color: #0f172a;"><%= tomorrowSlot.winner %></span></div>
          </div>
        <% } else { %>
          <div style="background: linear-gradient(to right, #fffbeb, #ffffff); border-left: 4px solid #f59e0b; padding: 24px; border-radius: 16px;">
            <div style="font-size: 10px; font-weight: 900; color: #92400e; text-transform: uppercase; letter-spacing: 0.1em;">System Status</div>
            <div style="font-size: 16px; font-weight: 900; color: #b45309; margin-top: 4px;">⏳ Open for Bidding</div>
            <div style="font-size: 13px; color: #92400e; margin-top: 8px; font-weight: 600;">Participate now to secure this date.</div>
          </div>
        <% } %>

        <% if(featuredProfile) { %>
          <div style="margin-top: 32px; padding-top: 24px; border-top: 1px solid #f1f5f9;">
            <div style="font-size: 11px; font-weight: 900; color: #94a3b8; text-transform: uppercase; letter-spacing: 0.15em; margin-bottom: 16px;">Current Featured Alumni</div>
            <div style="display: flex; align-items: center; gap: 16px;">
              <div style="width: 44px; height: 44px; border-radius: 50%; background: #f1f5f9; overflow: hidden; border: 2px solid #fff; box-shadow: 0 4px 10px rgba(0,0,0,0.05);">
                <% if(featuredProfile.profile_image) { %>
                  <img src="<%= featuredProfile.profile_image %>" style="width:100%; height:100%; object-fit:cover;">
                <% } %>
              </div>
              <div>
                <div style="font-size: 15px; font-weight: 900; color: #0f172a;"><%= featuredProfile.first_name %> <%= featuredProfile.last_name %></div>
                <div style="font-size: 12px; color: #64748b; font-weight: 700;"><%= featuredProfile.programme || 'Global Alumni' %></div>
              </div>
            </div>
          </div>
        <% } %>
      </div>
    </div>

    <!-- Strategy Guide -->
    <div class="bidding-card animate-fade-in" style="animation-delay: 0.3s; background: #0f172a; border: none;">
      <h3 style="color: #fff; margin-top: 0; font-size: 18px; font-weight: 900; letter-spacing: -0.03em; margin-bottom: 24px;">Auction Protocol</h3>
      <div style="display:grid; grid-template-columns: repeat(4, 1fr); gap:24px;">
        <div>
          <div style="color: #38bdf8; font-size: 10px; font-weight: 900; text-transform: uppercase; letter-spacing: 0.15em; margin-bottom: 8px;">01. Placement</div>
          <div style="color: #94a3b8; font-size: 13px; line-height: 1.6;">Daily sealed auction. Other bid amounts remain hidden until resolution.</div>
        </div>
        <div>
          <div style="color: #38bdf8; font-size: 10px; font-weight: 900; text-transform: uppercase; letter-spacing: 0.15em; margin-bottom: 8px;">02. Logic</div>
          <div style="color: #94a3b8; font-size: 13px; line-height: 1.6;">Feedback is limited to "Winning" or "Outbid" status only.</div>
        </div>
        <div>
          <div style="color: #38bdf8; font-size: 10px; font-weight: 900; text-transform: uppercase; letter-spacing: 0.15em; margin-bottom: 8px;">03. Constraints</div>
          <div style="color: #94a3b8; font-size: 13px; line-height: 1.6;">Bids can be increased anytime. Withdrawals permitted until 6 PM.</div>
        </div>
        <div>
          <div style="color: #38bdf8; font-size: 10px; font-weight: 900; text-transform: uppercase; letter-spacing: 0.15em; margin-bottom: 8px;">04. Resolution</div>
          <div style="color: #94a3b8; font-size: 13px; line-height: 1.6;">Automated winner selection by system cron job at peak time.</div>
        </div>
      </div>
    </div>

    <!-- History Log -->
    <div class="bidding-card animate-fade-in" style="animation-delay: 0.4s; padding: 0; overflow: hidden;">
      <div style="padding: 40px 48px 0;">
        <h3 style="margin: 0; font-size: 22px; font-weight: 900; color: #0f172a; letter-spacing: -0.04em;">Investment History</h3>
      </div>
      <table class="history-table">
        <thead>
          <tr>
            <th>Execution Date</th>
            <th>Bid Amount</th>
            <th>Outcome</th>
          </tr>
        </thead>
        <tbody>
          <% if(history.length === 0) { %>
            <tr><td colspan="3" style="text-align:center; padding:60px; color: #94a3b8; font-size: 14px;">No historical bid data available.</td></tr>
          <% } %>
          <% history.forEach(function(b) { %>
            <tr>
              <td><%= b.bid_date %></td>
              <td>£<%= parseFloat(b.amount).toFixed(2) %></td>
              <td>
                <% if(b.status === 'won') { %>
                  <span class="live-status-pill status-winning" style="padding: 6px 14px; font-size: 11px;">Won</span>
                <% } else if(b.status === 'lost') { %>
                  <span class="live-status-pill status-losing" style="padding: 6px 14px; font-size: 11px;">Lost</span>
                <% } else { %>
                  <span class="live-status-pill status-pending" style="padding: 6px 14px; font-size: 11px;">Active</span>
                <% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

  </div>
</div>

<%- include('../partials/footer') %>
