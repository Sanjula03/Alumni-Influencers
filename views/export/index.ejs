<%- include('../partials/header') %>
<%- include('../partials/sidebar') %>

<div class="main-content with-sidebar">
  <div class="top-header">
    <h2>Export & Report Generation</h2>
  </div>

  <%- include('../partials/flashData') %>

  <div class="card">
    <h3 style="margin-top:0;">Generate Custom Data Export</h3>
    <p style="color: var(--text-muted); font-size:13px; margin-bottom: 20px;">Filter the alumni dataset by programme, year, or sector, then export as CSV or a formatted PDF executive summary.</p>

    <div style="display:flex; gap: 40px;">
      
      <div style="flex:1;">
        <form id="exportForm" action="/export/csv" method="GET">
          <div style="margin-bottom: 15px;">
            <label>Filter by Programme:</label>
            <input type="text" id="filterProgramme" name="programme" placeholder="e.g. Computer Science" style="width:100%;">
          </div>
          <div style="margin-bottom: 15px;">
            <label>Filter by Graduation Year:</label>
            <input type="number" id="filterYear" name="year" placeholder="YYYY" style="width:100%;">
          </div>
          <div style="margin-bottom: 15px;">
            <label>Filter by Industry Sector:</label>
            <input type="text" id="filterSector" name="sector" placeholder="e.g. Technology" style="width:100%;">
          </div>

          <!-- Save/Load filter presets (rubric: "save filter presets") -->
          <div style="display:flex; gap:8px; margin-bottom:20px;">
            <button type="button" onclick="savePreset()" class="btn" style="flex:1; border:1px solid var(--border-color); color:var(--text-main); background:#ffffff; font-size:12px;">
              💾 Save Preset
            </button>
            <button type="button" onclick="loadPreset()" class="btn" style="flex:1; border:1px solid var(--border-color); color:var(--text-main); background:#ffffff; font-size:12px;">
              📂 Load Preset
            </button>
          </div>
          
          <div style="display:flex; gap:10px;">
            <button type="submit" onclick="document.getElementById('exportForm').action='/export/csv';" class="btn" style="flex:1; border: 1px solid var(--border-color); color: var(--text-main); background: #ffffff;">
              ⬇ Download CSV
            </button>
            <button type="submit" onclick="document.getElementById('exportForm').action='/export/pdf';" class="btn btn-primary" style="flex:1;">
              📄 Generate PDF
            </button>
          </div>
        </form>
      </div>

      <div style="flex:1; background: #f9fafb; border: 1px solid var(--border-color); padding: 20px; border-radius: 4px;">
        <h4 style="margin-top:0;">Available Fields in Export</h4>
        <ul style="color: var(--text-muted); font-size: 14px; line-height:1.6; padding-left: 20px;">
          <li>First Name & Last Name</li>
          <li>Programme Name</li>
          <li>Graduation Year</li>
          <li>Current Company</li>
          <li>Current Role</li>
          <li>Industry Sector</li>
          <li>Geographic Location</li>
        </ul>
        <div style="margin-top:16px; padding:12px; background:#ffffff; border:1px solid var(--border-color); border-radius:4px;">
          <p style="font-size:12px; color:#6b7280; margin:0;">
            <strong>CSV:</strong> Raw data with all fields above, suitable for spreadsheet analysis.<br>
            <strong>PDF:</strong> Executive summary with total counts, applied filters, and a formatted alumni list.
          </p>
        </div>
      </div>

    </div>
  </div>
</div>

<script>
  // Filter preset save/load using localStorage (rubric: "save filter presets")
  function savePreset() {
    const preset = {
      programme: document.getElementById('filterProgramme').value,
      year: document.getElementById('filterYear').value,
      sector: document.getElementById('filterSector').value
    };
    localStorage.setItem('exportPreset', JSON.stringify(preset));
    alert('Filter preset saved successfully!');
  }

  function loadPreset() {
    const saved = localStorage.getItem('exportPreset');
    if (!saved) { alert('No saved preset found.'); return; }
    const preset = JSON.parse(saved);
    document.getElementById('filterProgramme').value = preset.programme || '';
    document.getElementById('filterYear').value = preset.year || '';
    document.getElementById('filterSector').value = preset.sector || '';
    alert('Preset loaded!');
  }
</script>

<%- include('../partials/footer') %>

